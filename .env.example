# Anthropic API Key for running agent translations
ANTHROPIC_API_KEY=your_key_here

# ─── Prediction Market Auction (Web3) ─────────────────────────────────────
# Arc Testnet RPC endpoint
ARC_RPC_URL=https://rpc.testnet.arc.network

# Oracle signer private key (for ECDSA signatures verified on-chain)
ORACLE_PRIVATE_KEY=your_oracle_key_here

# Backend operator private key (for calling AuctionManager/MarketFactory)
BACKEND_PRIVATE_KEY=your_backend_key_here

# Deployed contract addresses (set after deployment)
AUCTION_MANAGER_ADDRESS=
MARKET_FACTORY_ADDRESS=
NFT_CONTRACT_ADDRESS=

# Optional: known PredictionMarket instance (markets are normally discovered
# dynamically via MarketFactory.getDeployedMarkets())
PREDICTION_MARKET_ADDRESS=

# Arc Testnet USDC address
USDC_ADDRESS=0x3600000000000000000000000000000000000000

# ─── Operator Addresses (comma-separated) ───────────────────────────────
# Only these addresses can create auctions via the UI and API.
# The public bidding panel is always available to any connected wallet.
OPERATOR_ADDRESSES=0xYourOperatorAddress1,0xYourOperatorAddress2

# ─── Expert Evaluator Wallet Addresses (Phase 1 decentralized evaluation) ──
# These identities represent expert agents that score shortlisted finalists.
# Set real wallet addresses to simulate decentralized expert participation.
EXPERT_1_ADDRESS=0xEXPERT1_CLARITY_JUDGE
EXPERT_2_ADDRESS=0xEXPERT2_MARKET_VIABILITY
EXPERT_3_ADDRESS=0xEXPERT3_OBJECTIVITY_GUARD
